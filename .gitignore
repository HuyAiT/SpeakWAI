# ============================================
# Data files (Training data, datasets)
# ============================================
# Ignore all CSV and large data files
ai_model/*.csv
ai_model/data/**/*.csv
backend/data/**/*.csv

# Ignore large JSON data files (but keep config files)
ai_model/*.json
ai_model/data/**/*.json
backend/data/**/*.json

# Keep these important JSON files
!package.json
!package-lock.json
!pubspec.lock
!tsconfig.json
!jsconfig.json

